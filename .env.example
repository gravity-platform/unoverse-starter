# =============================================================================
# GRAVITY PLATFORM - DEPLOYMENT CONFIGURATION
# =============================================================================
# This is the ONLY file you need to edit for deployment.
# Copy to .env and fill in your values.

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgres://user:password@host:5432/gravity

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false
REDIS_NAMESPACE=gravity

# =============================================================================
# OIDC AUTHENTICATION
# =============================================================================
# Works with: Auth0, Keycloak, Azure AD, Cognito, etc.

# Server-side (JWT validation)
AUTH_ISSUER=https://your-tenant.auth0.com
AUTH_CLIENT_ID=your-client-id
AUTH_AUDIENCE=gravity-api

# Client-side (SAB build-time args - same values as above)
VITE_AUTH_ISSUER=https://your-tenant.auth0.com
VITE_AUTH_CLIENT_ID=your-client-id
VITE_AUTH_AUDIENCE=gravity-api

# Set to true to disable authentication (local development only)
DISABLE_AUTH=false


# =============================================================================
# SERVICE URLS (for inter-service communication)
# =============================================================================
# Local development: use localhost (or leave unset - code has fallbacks)
# Docker: use container names (set in docker-compose.yml)
WORKFLOW_SERVICE_URL=http://localhost:4101
NODE_SERVICE_URL=http://localhost:4102
SERVER_WS_URL=ws://localhost:4100
API_URL=http://localhost:4100
UMAP_SERVICE_URL=http://localhost:5001
#update to production url
MCP_SERVICE_URL=http://localhost:4103

# =============================================================================
# DATABASE INITIALIZATION
# =============================================================================
# Set to true to skip database migrations on startup (for production)
SKIP_DB_INIT=true

# =============================================================================
# SAB API ENDPOINTS (Build-time args)
# =============================================================================
VITE_API_URL=http://localhost:4100
VITE_SERVER_WS_URL=ws://localhost:4100
# Node service URL for local dev (in deployed, Caddy proxies /plugins* to node-service)
VITE_NODE_SERVICE_URL=http://localhost:4102


# Amazon Connect Config
VITE_CONTACT_FLOW_ID=
VITE_INSTANCE_ID=
VITE_API_GATEWAY_ENDPOINT=
VITE_CONNECT_REGION=
VITE_APS_CUSTOMER_ENDPOINT=
VITE_CLOUDFRONT_ENDPOINT=
