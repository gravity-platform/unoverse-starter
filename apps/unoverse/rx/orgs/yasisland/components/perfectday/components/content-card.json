{
  "brief": "One experience of a chapter \u2014 exactly ONE real need/experience from the search results, never invented.",
  "type": "Box",
  "style": {
    "direction": "column",
    "align": "start",
    "gap": "3",
    "width": "full"
  },
  "children": [
    {
      "type": "Box",
      "style": {
        "position": "relative",
        "height": "50",
        "width": "full",
        "overflow": "hidden",
        "radius": "2xl"
      },
      "children": [
        {
          "type": "Image",
          "brief": {
            "description": "The image of THIS experience \u2014 never borrowed from another item.",
            "hydrate": "image"
          },
          "bind": {
            "src": "image",
            "alt": "title"
          },
          "style": {
            "position": "absolute",
            "inset": "0",
            "width": "full",
            "height": "full",
            "fit": "cover"
          }
        },
        {
          "type": "Box",
          "visibleWhen": "place",
          "style": {
            "position": "absolute",
            "inset": "auto auto 0 0",
            "zIndex": 2,
            "margin": "3",
            "direction": "row",
            "align": "center",
            "gap": "xs",
            "padding": [
              "xs",
              "3"
            ],
            "radius": "full",
            "background": "brand.yasisland.glass"
          },
          "children": [
            {
              "type": "Icon",
              "icon": "location",
              "style": {
                "width": "3",
                "height": "3",
                "color": "white"
              }
            },
            {
              "type": "Text",
              "brief": {
            "description": "The location name \u2014 the referenced result's own name serves unless you have a truer one.",
            "hydrate": "place",
            "maxLength": 50
          },
              "bind": {
                "value": "place"
              },
              "style": {
                "font": "caption",
                "color": "white",
                "lineHeight": "tight"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Text",
      "brief": {
            "description": "The experience in the guest's language \u2014 what they'd feel, not the venue's marketing name. 5-8 plain English words.",
            "hydrate": "title",
            "maxLength": 55
          },
      "bind": {
        "value": "title"
      },
      "style": {
        "font": "headline.sm",
        "weight": "bold",
        "color": "text.primary",
        "lineHeight": "tight"
      }
    },
    {
      "type": "Markdown",
      "brief": {
            "description": "1-2 sentences grounded ONLY in the source content \u2014 never invent facts, prices or times. May use **bold** on real place names; no other markdown.",
            "hydrate": "body",
            "maxLength": 240
          },
      "bind": {
        "value": "body"
      },
      "style": {
        "font": "body.md",
        "color": "text.secondary"
      }
    },
    {
      "type": "Ref",
      "ref": "cta-link",
      "visibleWhen": "link",
      "props": {
        "link": "link"
      }
    }
  ]
}
