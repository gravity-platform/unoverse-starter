{
  "type": "Box",
  "style": {
    "direction": "row",
    "width": "full",
    "height": "full",
    "overflow": "hidden",
    "background": "brand.yasisland.gradient"
  },
  "children": [
    {
      "$include": "components/core"
    },
    {
      "type": "ComponentSlot",
      "appWidth": "rail",
      "select": {
        "from": "all",
        "where": {
          "field": "defaultState",
          "eq": "list"
        }
      },
      "frame": {
        "type": "Box",
        "style": {
          "minWidth": 0,
          "height": "full",
          "direction": "column",
          "overflow": "hidden",
          "borderLeft": "subtle",
          "background": "surface.sunken"
        },
        "children": [
          {
            "type": "Box",
            "style": {
              "flex": "0 0 auto",
              "direction": "row",
              "justify": "end",
              "align": "center",
              "padding": "md",
              "paddingBottom": "0"
            },
            "children": [
              {
                "type": "Ref",
                "ref": "close-button"
              }
            ]
          },
          {
            "type": "Box",
            "style": {
              "flex": "1 1 auto",
              "minHeight": 0,
              "direction": "column",
              "gap": "md",
              "padding": "md",
              "overflow": "auto"
            },
            "children": [
              {
                "type": "ComponentSlot"
              }
            ]
          }
        ]
      }
    }
  ]
}