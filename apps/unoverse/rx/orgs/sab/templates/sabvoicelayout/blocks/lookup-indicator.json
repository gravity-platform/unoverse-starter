{
  "type": "Box",
  "visibleWhen": "isLookingUp",
  "style": { "direction": "row", "align": "center", "gap": "md", "padding": ["3", "5"], "radius": "full", "background": "surface.base", "border": "subtle", "shadow": "sm" },
  "children": [
    {
      "type": "Each",
      "bind": { "items": "lookupDots" },
      "style": { "direction": "row", "align": "center", "gap": "xs" },
      "template": {
        "type": "Box",
        "style": { "width": "1.5", "height": "1.5", "radius": "full", "background": "action.primary", "animation": { "name": "wave", "duration": "1.2s", "easing": "ease-in-out" }, "animationDelay": "{{delay}}" }
      }
    },
    { "type": "Text", "bind": { "value": "lookupLabel" }, "style": { "font": "body.sm", "weight": "medium", "color": "text.secondary" } }
  ]
}
