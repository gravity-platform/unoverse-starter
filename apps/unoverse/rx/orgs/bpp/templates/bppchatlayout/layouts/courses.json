{
  "type": "Box",
  "style": {
    "direction": "row",
    "width": "full",
    "height": "full",
    "overflow": "hidden",
    "background": "brand.bpp.gradient-dark"
  },
  "children": [
    {
      "$include": "components/core"
    },
    {
      "type": "ComponentSlot",
      "appWidth": "flex",
      "select": {
        "from": "all",
        "where": {
          "field": "defaultState",
          "eq": "courses"
        }
      },
      "frame": {
        "type": "Box",
        "style": {
          "minWidth": 0,
          "height": "full",
          "direction": "column",
          "overflow": "hidden",
          "background": "brand.bpp.night"
        },
        "children": [
          {
            "type": "Box",
            "style": {
              "direction": "column",
              "justify": "center",
              "gap": "1",
              "height": "20",
              "padding": [
                "0",
                "lg"
              ],
              "background": "brand.bpp.ink-emphasis"
            },
            "children": [
              {
                "type": "Text",
                "value": "Courses",
                "style": {
                  "font": "headline.sm",
                  "weight": "semibold",
                  "color": "text.inverse"
                }
              },
              {
                "type": "Text",
                "value": "Explore programmes matched to you",
                "style": {
                  "font": "body.sm",
                  "color": "text.inverse"
                }
              }
            ]
          },
          {
            "type": "Box",
            "style": {
              "flex": 1,
              "minHeight": "0",
              "overflow": "auto",
              "columns": 2,
              "gap": "md",
              "padding": [
                "0",
                "lg",
                "lg",
                "lg"
              ]
            },
            "children": [
              {
                "type": "ComponentSlot"
              }
            ]
          }
        ]
      }
    }
  ]
}
