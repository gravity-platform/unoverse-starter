# Gravity Platform Environment Variables
# Generated by Ansible - Do not edit manually

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL={{ vault_database_url }}

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST={{ vault_redis_host }}
REDIS_PORT={{ vault_redis_port }}
REDIS_TLS=false
REDIS_NAMESPACE=gravity

# =============================================================================
# OIDC AUTHENTICATION
# =============================================================================
AUTH_ISSUER={{ vault_auth_issuer }}
AUTH_CLIENT_ID={{ vault_auth_client_id }}
AUTH_AUDIENCE={{ vault_auth_audience }}

# Client-side (same values)
VITE_AUTH_ISSUER={{ vault_auth_issuer }}
VITE_AUTH_CLIENT_ID={{ vault_auth_client_id }}
VITE_AUTH_AUDIENCE={{ vault_auth_audience }}

DISABLE_AUTH=false

# =============================================================================
# SERVICE URLS (Docker internal)
# =============================================================================
WORKFLOW_SERVICE_URL=http://workflow:4101
NODE_SERVICE_URL=http://node-service:4102
SERVER_WS_URL=ws://server:4100
API_URL=http://server:4100
UMAP_SERVICE_URL=http://umap:5001
MCP_SERVICE_URL=http://mcp-server:4103

# =============================================================================
# SAB API ENDPOINTS
# =============================================================================
VITE_API_URL=http://server:4100
VITE_SERVER_WS_URL=ws://server:4100
VITE_NODE_SERVICE_URL=http://node-service:4102

# =============================================================================
# AWS (for Bedrock/S3) - optional
# =============================================================================
{% if vault_aws_access_key_id %}
AWS_ACCESS_KEY_ID={{ vault_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ vault_aws_secret_access_key }}
AWS_REGION={{ vault_aws_region }}
{% endif %}

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
