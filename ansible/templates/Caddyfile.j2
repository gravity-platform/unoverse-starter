# Gravity Platform - Caddy Reverse Proxy Configuration
# Auto-generated by Ansible. Domain: {{ domain }}
#
# Caddy automatically provisions Let's Encrypt TLS certificates.

# Canvas UI - root domain
{{ domain }} {
    reverse_proxy localhost:3001
}

# API Server
api.{{ domain }} {
    reverse_proxy localhost:4100
}

# MCP Server (OpenAI integration)
mcp.{{ domain }} {
    reverse_proxy localhost:4103
}

# NOTE: SAB is deployed separately to CDN (Vercel/Netlify).
# If you need to host SAB on this server, add:
# sab.{{ domain }} {
#     reverse_proxy localhost:3007
# }
