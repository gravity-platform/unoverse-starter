# =============================================================================
# GRAVITY PLATFORM - PRODUCTION CONFIGURATION
# =============================================================================
# Copy to .env and fill in your values.
# This file is synced to gravity-starter for customer deployments.

# =============================================================================
# GHCR (GitHub Container Registry) - Gravity's Docker images
# =============================================================================
GHCR_USERNAME=your-github-username
GHCR_TOKEN=ghp_your_pat_here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://user:password@host:5432/gravity

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true
REDIS_NAMESPACE=gravity

# =============================================================================
# OIDC AUTHENTICATION
# =============================================================================
AUTH_ISSUER=https://your-tenant.auth0.com
AUTH_CLIENT_ID=your-client-id
AUTH_AUDIENCE=gravity-api

# =============================================================================
# DOMAIN
# =============================================================================
# Your domain for public URLs. URLs are derived automatically:
#   api.${DOMAIN} → API server (https://api.example.com)
#   mcp.${DOMAIN} → MCP server (https://mcp.example.com)
DOMAIN=example.com
