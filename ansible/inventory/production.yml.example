# Gravity Platform Production Inventory
# Copy to production.yml and update with your values

all:
  vars:
    # Docker image registry
    docker_registry: ghcr.io/gravity-platform
    gravity_version: latest
    
    # Shared services (customer-managed)
    redis_host: "{{ vault_redis_host }}"
    redis_port: 6379
    postgres_host: "{{ vault_postgres_host }}"
    postgres_port: 5432
    postgres_db: gravity
    
  children:
    app_vms:
      hosts:
        app-vm-1:
          ansible_host: 10.0.1.10
          ansible_user: gravity
        app-vm-2:
          ansible_host: 10.0.1.11
          ansible_user: gravity
      vars:
        # Services to run on app VMs
        gravity_services:
          - server
          - workflow
          - node-service
          - mcp-server
          - canvas
    
    ml_vms:
      hosts:
        ml-vm-1:
          ansible_host: 10.0.1.20
          ansible_user: gravity
      vars:
        # Services to run on ML VMs
        gravity_services:
          - umap
