# Gravity Platform Production Inventory
# Copy to production.yml and update with your values
#
# POC:        Single VM — use the default config below
# Enterprise: Uncomment the multi-VM section at the bottom

# =============================================================================
# POC — Single VM (all services on one host)
# =============================================================================
all:
  vars:
    starter_repo: "https://github.com/your-org/your-gravity.git"
    starter_branch: main

  hosts:
    gravity-prod:
      ansible_host: <YOUR_VM_IP>
      ansible_user: root

