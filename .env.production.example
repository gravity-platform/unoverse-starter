# =============================================================================
# GRAVITY PLATFORM - PRODUCTION DEPLOYMENT
# =============================================================================
# Copy to .env.production and fill in your values.
# This file configures both WHERE to deploy and HOW services run on the server.
#
# To deploy:  gravity deploy
#
# For multi-VM enterprise setups, use ansible/inventory/ instead.
# See ansible/inventory/production.yml.example for complex topologies.

# =============================================================================
# DEPLOY TARGET
# =============================================================================
# VM to deploy to. Ansible connects via SSH.
DEPLOY_HOST=your-vm-ip
DEPLOY_USER=root

# Azure: DEPLOY_USER=azureuser
# AWS:   DEPLOY_USER=ubuntu
# GCP:   DEPLOY_USER=debian

# =============================================================================
# CONTAINER REGISTRY
# =============================================================================
DOCR_TOKEN=dop_v1_your_token_here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://user:password@host:5432/gravity

# =============================================================================
# REDIS (Managed Redis for production)
# =============================================================================
# Unlike .env (which uses host.docker.internal for local dev),
# production requires a managed Redis instance with TLS.
# DigitalOcean Managed Redis uses port 25061; AWS ElastiCache uses 6379.
REDIS_HOST=your-redis-host.com
REDIS_PORT=25061
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true
REDIS_NAMESPACE=gravity

# =============================================================================
# OIDC AUTHENTICATION
# =============================================================================
AUTH_ISSUER=https://your-tenant.auth0.com
AUTH_CLIENT_ID=your-client-id
AUTH_AUDIENCE=gravity-api

# =============================================================================
# OPENAI (Required for Memory Server)
# =============================================================================
OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# DOMAIN (drives HTTPS URLs via Caddy)
# =============================================================================
# When set, docker-compose derives:
#   VITE_API_URL=https://api.${DOMAIN}
#   VITE_SERVER_WS_URL=wss://api.${DOMAIN}
DOMAIN=yourdomain.com

